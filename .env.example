# API Configuration
# 
# NOTE: Anda bisa mengganti URL Odoo langsung dari halaman login!
#       URL akan otomatis tersimpan di browser tanpa perlu mengubah file ini.
# 
# Gunakan VITE_API_BASE_URL ini sebagai default/fallback jika tidak input URL di login page.

## Development (Odoo berjalan di localhost)
VITE_API_BASE_URL=http://localhost:8069

## Production — same-origin via Nginx reverse proxy
# Kosongkan nilai ini agar frontend menggunakan relative path (/api/...)
# Nginx di domain frontend harus mem-proxy /api/* ke backend Odoo.
# VITE_API_BASE_URL=

## Production — cross-origin langsung ke Odoo (butuh CORS di Odoo)
# VITE_API_BASE_URL=https://kanjabung.web.id
