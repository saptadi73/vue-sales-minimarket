# API Configuration
# 
# NOTE: Anda bisa mengganti URL Odoo langsung dari halaman login!
#       URL akan otomatis tersimpan di browser tanpa perlu mengubah file ini.
# 
# Gunakan VITE_API_BASE_URL ini sebagai default/fallback jika tidak input URL di login page.

## Development
VITE_API_BASE_URL=http://localhost:8069

## Production
# VITE_API_BASE_URL=https://odoo.yourdomain.com
